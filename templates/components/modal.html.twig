{# Composant modal générique réutilisable #}
{# Paramètres: modal_id, modal_title, form_content #}

<div id="{{ modal_id }}-overlay" 
     onclick="closeModal('{{ modal_id }}')" 
     style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:100; align-items:center; justify-content:center;">
    
    <div onclick="event.stopPropagation()" 
         style="background:#fff; border-radius:12px; padding:1.5rem; width:100%; max-width:560px; margin: 0 1rem; max-height: 80vh; overflow-y: auto;">
        
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.25rem;">
            <span style="font-size:15px; font-weight:500;">{{ modal_title }}</span>
            <button onclick="closeModal('{{ modal_id }}')" 
                    style="background:none; border:none; font-size:18px; cursor:pointer; color:#888780;">✕</button>
        </div>

        {{ form_content | raw }}

        <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:1.25rem;">
            <button type="button" class="btn" onclick="closeModal('{{ modal_id }}')">Annuler</button>
            <button type="submit" form="{{ form_id }}" class="btn btn-primary">Enregistrer</button>
        </div>
    </div>
</div>

<script>
    function openModal(modalId) {
        const modal = document.getElementById(modalId + '-overlay');
        if (modal) {
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }
    }

    function closeModal(modalId) {
        const modal = document.getElementById(modalId + '-overlay');
        if (modal) {
            modal.style.display = 'none';
            document.body.style.overflow = '';
        }
    }

    // Fermer avec Echap
    document.addEventListener('keydown', e => {
        if (e.key === 'Escape') {
            document.querySelectorAll('[id$="-overlay"]').forEach(modal => {
                if (modal.style.display === 'flex') {
                    modal.style.display = 'none';
                    document.body.style.overflow = '';
                }
            });
        }
    });
</script>
