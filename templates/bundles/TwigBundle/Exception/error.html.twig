<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Erreur {{ status_code }}{% endblock %} — BiblioConnect</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #f8fafc;
            color: #1a1a2e;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── Navbar ── */
        .err-nav {
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
            padding: 0 24px;
            height: 60px;
            display: flex;
            align-items: center;
        }

        .err-nav a {
            text-decoration: none;
            font-size: 1.2rem;
            font-weight: 800;
            color: #1a1a2e;
            letter-spacing: -.5px;
        }

        .err-nav a span { color: #3b82f6; }

        /* ── Main ── */
        .err-main {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 48px 24px;
        }

        .err-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 20px;
            padding: 56px 48px;
            max-width: 560px;
            width: 100%;
            text-align: center;
            box-shadow: 0 4px 32px rgba(0,0,0,.06);
        }

        .err-code {
            font-size: 6rem;
            font-weight: 900;
            line-height: 1;
            background: linear-gradient(135deg, #667eea 0%, #3b82f6 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
            letter-spacing: -4px;
        }

        .err-icon {
            font-size: 2.8rem;
            margin-bottom: 20px;
        }

        .err-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 12px;
        }

        .err-desc {
            font-size: .95rem;
            color: #6b7280;
            line-height: 1.6;
            margin-bottom: 36px;
        }

        .err-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }

        .err-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 11px 22px;
            border-radius: 10px;
            font-size: .9rem;
            font-weight: 600;
            text-decoration: none;
            transition: all .18s;
        }

        .err-btn-primary {
            background: #3b82f6;
            color: #fff;
        }

        .err-btn-primary:hover { background: #2563eb; }

        .err-btn-ghost {
            background: #f3f4f6;
            color: #374151;
            border: 1px solid #e5e7eb;
        }

        .err-btn-ghost:hover { background: #e5e7eb; }

        /* ── Footer ── */
        .err-footer {
            text-align: center;
            padding: 20px;
            font-size: .78rem;
            color: #9ca3af;
        }

        @media (max-width: 480px) {
            .err-card { padding: 36px 24px; }
            .err-code { font-size: 4.5rem; }
        }
    </style>
</head>
<body>

    <header class="err-nav">
        <a href="/">Biblio<span>Connect</span></a>
    </header>

    <main class="err-main">
        <div class="err-card">

            <div class="err-code">{{ status_code }}</div>

            {% block err_icon %}
                {% if status_code == 404 %}
                    <div class="err-icon">🔍</div>
                {% elseif status_code == 403 %}
                    <div class="err-icon">🔒</div>
                {% elseif status_code == 500 %}
                    <div class="err-icon">⚙️</div>
                {% elseif status_code == 503 %}
                    <div class="err-icon">🛠️</div>
                {% elseif status_code == 429 %}
                    <div class="err-icon">⏱️</div>
                {% else %}
                    <div class="err-icon">⚠️</div>
                {% endif %}
            {% endblock %}

            <h1 class="err-title">
                {% block err_title %}
                    {% if status_code == 404 %}
                        Page introuvable
                    {% elseif status_code == 403 %}
                        Accès refusé
                    {% elseif status_code == 500 %}
                        Erreur interne du serveur
                    {% elseif status_code == 503 %}
                        Service temporairement indisponible
                    {% elseif status_code == 429 %}
                        Trop de requêtes
                    {% elseif status_code == 401 %}
                        Authentification requise
                    {% else %}
                        Une erreur s'est produite
                    {% endif %}
                {% endblock %}
            </h1>

            <p class="err-desc">
                {% block err_desc %}
                    {% if status_code == 404 %}
                        La page que vous recherchez n'existe pas ou a été déplacée.
                        Vérifiez l'adresse ou retournez à l'accueil.
                    {% elseif status_code == 403 %}
                        Vous n'avez pas les droits nécessaires pour accéder à cette ressource.
                        Connectez-vous avec un compte autorisé.
                    {% elseif status_code == 500 %}
                        Quelque chose s'est mal passé de notre côté. Notre équipe a été alertée.
                        Veuillez réessayer dans quelques instants.
                    {% elseif status_code == 503 %}
                        Le service est temporairement en maintenance. Revenez très prochainement.
                    {% elseif status_code == 429 %}
                        Vous avez effectué trop de requêtes en peu de temps. Attendez un moment avant de réessayer.
                    {% elseif status_code == 401 %}
                        Vous devez être connecté pour accéder à cette page.
                    {% else %}
                        Une erreur inattendue s'est produite ({{ status_code }} — {{ status_text }}).
                        Veuillez réessayer ou contacter l'administrateur.
                    {% endif %}
                {% endblock %}
            </p>

            <div class="err-actions">
                {% block err_actions %}
                    <a href="/" class="err-btn err-btn-primary">
                        <i class="fa fa-house"></i> Accueil
                    </a>
                    {% if status_code == 403 %}
                        <a href="/login" class="err-btn err-btn-ghost">
                            <i class="fa fa-arrow-right-to-bracket"></i> Se connecter
                        </a>
                    {% else %}
                        <a href="/catalogue" class="err-btn err-btn-ghost">
                            <i class="fa fa-book-open"></i> Catalogue
                        </a>
                    {% endif %}
                {% endblock %}
            </div>

        </div>
    </main>

    <footer class="err-footer">
        &copy; {{ "now"|date("Y") }} BiblioConnect — Erreur {{ status_code }}
    </footer>

</body>
</html>
