{% extends 'base.html.twig' %}

{% block title %}{{ book.title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/flatpickr.min.css') }}">
    <style>
        /* ── Breadcrumb ── */
        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: .85rem;
            color: #9ca3af;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .breadcrumb a {
            color: #6b7280;
            text-decoration: none;
            transition: color .15s;
        }

        .breadcrumb a:hover { color: #3b82f6; }

        .breadcrumb .sep { color: #d1d5db; }

        .breadcrumb .current {
            color: #1a1a2e;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 260px;
        }

        .book-show-wrapper {
            max-width: 960px;
            margin: 40px auto;
            padding: 0 20px;
            font-family: sans-serif;
        }

        /* ── Book header ── */
        .book-header {
            display: flex;
            gap: 30px;
            align-items: flex-start;
            margin-bottom: 40px;
        }

        .book-cover {
            flex-shrink: 0;
            width: 180px;
            height: 260px;
            border-radius: 10px;
            overflow: hidden;
            background: #e0e0e0;
            box-shadow: 4px 6px 18px rgba(0,0,0,.15);
        }

        .book-cover img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .book-meta {
            flex: 1;
        }

        .book-meta h1 {
            margin: 0 0 8px;
            font-size: 1.8rem;
            color: #1a1a2e;
        }

        .book-meta .author {
            color: #555;
            margin-bottom: 14px;
            font-size: 1rem;
        }

        .book-meta .description {
            color: #444;
            line-height: 1.6;
            margin-bottom: 16px;
        }

        .badge {
            display: inline-block;
            padding: 5px 14px;
            border-radius: 20px;
            font-size: .8rem;
            font-weight: 600;
            letter-spacing: .4px;
        }
        .badge-available   { background: #d4edda; color: #155724; }
        .badge-unavailable { background: #f8d7da; color: #721c24; }

        /* ── Favorite button ── */
        .fav-btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 7px 16px;
            border: 1.5px solid #e5e7eb;
            border-radius: 20px;
            background: #fff;
            color: #6b7280;
            font-size: .85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all .2s;
        }

        .fav-btn:hover, .fav-btn--active {
            border-color: #e74c3c;
            color: #e74c3c;
            background: #fff5f5;
        }

        /* ── Reservation section ── */
        .reservation-section {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 14px;
            padding: 30px;
            box-shadow: 0 2px 12px rgba(0,0,0,.06);
        }

        .reservation-section h2 {
            margin: 0 0 6px;
            font-size: 1.25rem;
            color: #1a1a2e;
        }

        .reservation-section p.hint {
            color: #888;
            font-size: .9rem;
            margin-bottom: 20px;
        }

        /* flatpickr inline wrapper */
        .fp-wrap {
            display: flex;
            gap: 24px;
            flex-wrap: wrap;
            align-items: flex-start;
        }

        .fp-inline-container {
            flex-shrink: 0;
        }

        /* Override flatpickr inline border */
        .flatpickr-calendar.inline {
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            box-shadow: none;
        }

        /* ── Form side ── */
        .reservation-form {
            flex: 1;
            min-width: 220px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .form-group label {
            display: block;
            font-size: .85rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
        }

        .form-group input[type="text"] {
            width: 100%;
            padding: 9px 12px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            font-size: .95rem;
            background: #f9fafb;
            color: #111;
            box-sizing: border-box;
        }

        .form-group input[type="text"]:read-only {
            background: #f3f4f6;
            cursor: default;
        }

        .legend {
            display: flex;
            flex-direction: column;
            gap: 6px;
            font-size: .82rem;
            color: #555;
        }

        .legend span {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .legend-dot {
            width: 12px;
            height: 12px;
            border-radius: 3px;
            flex-shrink: 0;
        }
        .dot-reserved { background: #e74c3c; }
        .dot-selected { background: #3b82f6; }

        .btn-reserve {
            margin-top: 8px;
            padding: 12px;
            background: #3b82f6;
            color: #fff;
            font-size: 1rem;
            font-weight: 600;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: background .2s;
        }

        .btn-reserve:hover   { background: #2563eb; }
        .btn-reserve:disabled {
            background: #9ca3af;
            cursor: not-allowed;
        }

        /* ── Comment section ── */
        .comment-section {
            margin-top: 38px;
        }

        .comment-section-title {
            font-size: 1.15rem;
            font-weight: 700;
            color: #1a1a2e;
            margin: 0 0 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* ── Write form ── */
        .comment-form-card {
            background: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 14px;
            padding: 28px;
            margin-bottom: 28px;
            box-shadow: 0 2px 12px rgba(0,0,0,.06);
        }

        .comment-form-card h3 {
            font-size: 1rem;
            font-weight: 700;
            color: #1a1a2e;
            margin: 0 0 16px;
        }

        /* ── Star rating ── */
        .star-rating {
            display: flex;
            flex-direction: row-reverse;
            justify-content: flex-end;
            gap: 4px;
            margin-bottom: 16px;
        }

        .star-rating input[type="radio"] { display: none; }

        .star-rating label {
            font-size: 2rem;
            color: #d1d5db;
            cursor: pointer;
            transition: color .15s, transform .1s;
            line-height: 1;
        }

        .star-rating label:hover,
        .star-rating label:hover ~ label,
        .star-rating input:checked ~ label {
            color: #f59e0b;
        }

        .star-rating label:hover { transform: scale(1.15); }

        /* ── Textarea ── */
        .comment-textarea {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #d1d5db;
            border-radius: 10px;
            font-size: .95rem;
            font-family: inherit;
            line-height: 1.5;
            color: #374151;
            background: #f9fafb;
            resize: vertical;
            min-height: 100px;
            box-sizing: border-box;
            transition: border-color .2s, box-shadow .2s;
        }

        .comment-textarea:focus {
            outline: none;
            border-color: #3b82f6;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(59,130,246,.12);
        }

        .btn-submit-comment {
            margin-top: 12px;
            padding: 10px 24px;
            background: #3b82f6;
            color: #fff;
            font-size: .95rem;
            font-weight: 600;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: background .2s;
        }

        .btn-submit-comment:hover { background: #2563eb; }

        /* ── Comment list ── */
        .comment-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .comment-card {
            background: #fff;
            border: 1px solid #f1f3f5;
            border-radius: 12px;
            padding: 18px 22px;
            box-shadow: 0 1px 4px rgba(0,0,0,.04);
        }

        .comment-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }

        .comment-author {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .comment-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: #fff;
            font-weight: 700;
            font-size: .8rem;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .comment-name {
            font-weight: 600;
            color: #1a1a2e;
            font-size: .9rem;
        }

        .comment-date {
            font-size: .78rem;
            color: #9ca3af;
        }

        .comment-stars {
            color: #f59e0b;
            font-size: .95rem;
            letter-spacing: 1px;
        }

        .comment-stars .empty-star { color: #d1d5db; }

        .comment-body {
            color: #374151;
            font-size: .9rem;
            line-height: 1.6;
        }

        .comment-empty {
            color: #9ca3af;
            font-size: .9rem;
            text-align: center;
            padding: 32px;
        }

        .flash-success {
            background: #d1fae5;
            color: #065f46;
            border: 1px solid #a7f3d0;
            border-radius: 8px;
            padding: 10px 16px;
            margin-bottom: 20px;
            font-size: .9rem;
        }

        .flash-error {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fecaca;
            border-radius: 8px;
            padding: 10px 16px;
            margin-bottom: 20px;
            font-size: .9rem;
        }

        @media (max-width: 640px) {
            .book-header { flex-direction: column; }
            .book-cover  { width: 100%; height: 220px; }
        }
    </style>
{% endblock %}

{% block body %}
<div class="book-show-wrapper">

    {# ── Fil d'ariane ── #}
    <nav class="breadcrumb" aria-label="Fil d'ariane">
        <a href="{{ path('app_home') }}"><i class="fa fa-house fa-sm"></i> Accueil</a>
        <span class="sep">›</span>
        <a href="{{ path('app_book_index') }}">Catalogue</a>
        <span class="sep">›</span>
        <span class="current">{{ book.title }}</span>
    </nav>

    {# ── Book info ── #}
    <div class="book-header">
        <div class="book-cover">
            {% if book.image %}
                <img src="{{ asset('images/' ~ book.image) }}" alt="{{ book.title }}">
            {% endif %}
        </div>

        <div class="book-meta">
            <h1>{{ book.title }}</h1>
            <p class="author"><i class="fa fa-pen-nib"></i> {{ book.author.getAllName }}</p>
            <p class="description">{{ book.description }}</p>

            <div style="display:flex; align-items:center; gap:14px; flex-wrap:wrap;">
                <span class="badge {{ book.stock > 0 ? 'badge-available' : 'badge-unavailable' }}">
                    {{ book.stock > 0 ? 'Disponible' : 'Indisponible' }}
                </span>

                {% if app.user %}
                    <button id="favBtn"
                            class="fav-btn {{ isFavorite ? 'fav-btn--active' : '' }}"
                            data-book-id="{{ book.id }}"
                            title="{{ isFavorite ? 'Retirer des favoris' : 'Ajouter aux favoris' }}">
                        <i class="{{ isFavorite ? 'fa-solid' : 'fa-regular' }} fa-heart"></i>
                        <span>{{ isFavorite ? 'Retirer des favoris' : 'Ajouter aux favoris' }}</span>
                    </button>
                {% endif %}
            </div>
            <div style="margin-top:12px; color:#f59e0b; font-size:1.1rem;">
                {% if book.averageRating is not null %}
                    {% for i in 1..5 %}
                        {% if i <= book.averageRating|round(0, 'floor') %}
                            <i class="fa-solid fa-star"></i>
                        {% elseif i - book.averageRating < 1 %}
                            <span style="position:relative; display:inline-block; color:#fbbf24;">
                                <i class="fa-solid fa-star"></i>
                                <span style="position:absolute; top:0; left:0; width:{{ (book.averageRating - (i - 1)) * 100 }}%; overflow:hidden; white-space:nowrap; color:#d1d5db;">
                                </span>
                            </span>
                        {% else %}
                            <i class="fa-regular fa-star"></i>
                        {% endif %}
                    {% endfor %}
                    <span style="font-size:.85rem;font-weight:500;color:#9ca3af; margin-left:6px;">
                        ({{ book.averageRating|number_format(1, '.', ',') }}/5)
                    </span>
                {% else %}
                    <span style="font-size:.85rem;font-weight:500;color:#9ca3af;">
                        Pas encore noté
                    </span>
                {% endif %}
                </div>
        </div>
    </div>

    {# ── Reservation ── #}
    {% if book.stock > 0 %}
        {% if app.user %}
        <div class="reservation-section">
            <h2>Réserver ce livre</h2>
            <p class="hint">Sélectionnez une période sur le calendrier. Les dates en rouge sont déjà réservées.</p>

            <form method="post" action="{{ path('app_reservation_create', {id: book.id}) }}" id="reservationForm">
                <div class="fp-wrap">

                    {# Inline flatpickr will render here #}
                    <div class="fp-inline-container">
                        <input type="text" id="datePicker" placeholder="Choisir les dates..." style="display:none;">
                    </div>

                    <div class="reservation-form">
                        <div class="form-group">
                            <label for="dateDebut">Date de début</label>
                            <input type="text" id="dateDebutDisplay" placeholder="--/--/----" readonly>
                            <input type="hidden" name="dateDebut" id="dateDebut">
                        </div>

                        <div class="form-group">
                            <label for="dateFin">Date de fin</label>
                            <input type="text" id="dateFinDisplay" placeholder="--/--/----" readonly>
                            <input type="hidden" name="dateFin" id="dateFin">
                        </div>

                        <div class="legend">
                            <span><span class="legend-dot dot-reserved"></span> Période déjà réservée</span>
                            <span><span class="legend-dot dot-selected"></span> Votre sélection</span>
                        </div>

                        <button type="submit" class="btn-reserve" id="btnReserve" disabled>
                            Confirmer la réservation
                        </button>
                    </div>

                </div>
            </form>
        </div>
        {% else %}
        <div class="reservation-section" style="text-align:center; color:#1a1a2e;">
            <p><i class="fa fa-lock"></i> Vous devez <a href="{{ path('app_login') }}">vous connecter</a> pour réserver ce livre.</p>
        </div>
        {% endif %}
    {% else %}
    <div class="reservation-section" style="text-align:center; color:#721c24;">
        <p>Ce livre n'est actuellement pas disponible à la réservation.</p>
    </div>
    {% endif %}

    {# ── Flash messages ── #}
    {% for msg in app.flashes('success') %}
        <div class="flash-success"><i class="fas fa-check-circle"></i> {{ msg }}</div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
        <div class="flash-error"><i class="fas fa-exclamation-circle"></i> {{ msg }}</div>
    {% endfor %}

    {# ══════════════════════════════════════
       SECTION COMMENTAIRES
    ══════════════════════════════════════ #}
    <div class="comment-section">
        <h2 class="comment-section-title">
            <i class="fas fa-comments" style="color:#3b82f6;"></i>
            Avis des lecteurs
            {% if comments|length > 0 %}
                <span style="font-size:.85rem;font-weight:500;color:#9ca3af;">({{ comments|length }})</span>
            {% endif %}
        </h2>

        {# ── Formulaire (uniquement si réservation terminée) ── #}
        {% if canComment %}
        <div class="comment-form-card">
            <h3>
                {% if userComment %}
                    <i class="fas fa-pen"></i> Modifier votre avis
                {% else %}
                    <i class="fas fa-star"></i> Laisser un avis
                {% endif %}
            </h3>

            <form method="post" action="{{ path('app_book_comment', {id: book.id}) }}">

                {# ── Stars ── #}
                <div class="star-rating" id="starRating">
                    {% for i in 5..1 %}
                    <input type="radio" name="note" id="star{{ i }}" value="{{ i }}"
                           {{ userComment and userComment.note == i ? 'checked' : '' }}>
                    <label for="star{{ i }}" title="{{ i }} étoile{{ i > 1 ? 's' : '' }}">&#9733;</label>
                    {% endfor %}
                </div>
                <div id="starLabel" style="font-size:.82rem;color:#9ca3af;margin-bottom:14px;">
                    {% if userComment %}
                        {{ userComment.note }}/5 — modifiez votre note en cliquant sur les étoiles
                    {% else %}
                        Cliquez sur les étoiles pour noter
                    {% endif %}
                </div>

                {# ── Text ── #}
                <textarea name="contents" class="comment-textarea"
                          placeholder="Partagez votre expérience de lecture…" required
                          maxlength="2000">{{ userComment ? userComment.contents : '' }}</textarea>

                <button type="submit" class="btn-submit-comment">
                    <i class="fas fa-paper-plane"></i>
                    {{ userComment ? 'Mettre à jour' : 'Publier' }}
                </button>
            </form>
        </div>
        {% elseif app.user %}
        <div style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:16px 20px;margin-bottom:24px;font-size:.9rem;color:#92400e;">
            <i class="fas fa-info-circle"></i>
            Vous pourrez laisser un avis une fois votre réservation de ce livre clôturée.
        </div>
        {% endif %}

        {# ── Liste des commentaires publiés ── #}
        {% if comments is empty %}
            <div class="comment-empty">
                <i class="fas fa-comment-slash" style="font-size:1.8rem;opacity:.3;display:block;margin-bottom:8px;"></i>
                Aucun avis pour le moment. Soyez le premier à en laisser un !
            </div>
        {% else %}
            <div class="comment-list">
                {% for c in comments %}
                <div class="comment-card">
                    <div class="comment-card-header">
                        <div class="comment-author">
                            <div class="comment-avatar">
                                {{ c.user ? c.user.prenom|slice(0,1)|upper ~ c.user.nom|slice(0,1)|upper : '?' }}
                            </div>
                            <div>
                                <div class="comment-name">
                                    {{ c.user ? c.user.prenom ~ ' ' ~ c.user.nom : 'Utilisateur' }}
                                    {% if app.user and c.user and c.user.id == app.user.id %}
                                        <span style="font-size:.75rem;background:#e0e7ff;color:#667eea;border-radius:4px;padding:2px 6px;margin-left:6px;">Vous</span>
                                    {% endif %}
                                </div>
                                <div class="comment-date">{{ c.createdAt|date('d/m/Y') }}</div>
                            </div>
                        </div>
                        <div class="comment-stars">
                            {% for s in 1..5 %}
                                {% if s <= c.note %}
                                    <span>&#9733;</span>
                                {% else %}
                                    <span class="empty-star">&#9733;</span>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    <div class="comment-body">{{ c.contents }}</div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

</div>

{# ── JS : flatpickr (chargement asynchrone à la demande) ── #}
<script>
(function () {
    var FLATPICKR_URL = "{{ asset('scripts/flatpickr.js') }}";

    var reservedRanges = [
        {% for r in listReservation %}
        {
            from: "{{ r.start|date('Y-m-d') }}",
            to:   "{{ r.end|date('Y-m-d') }}"
        }{% if not loop.last %},{% endif %}
        {% endfor %}
    ];

    function loadFlatpickr() {
        return new Promise(function (resolve) {
            if (window.flatpickr) { resolve(); return; }
            var s = document.createElement('script');
            s.src = FLATPICKR_URL;
            s.async = true;
            s.onload = resolve;
            s.onerror = function () {
                console.error('Impossible de charger flatpickr depuis : ' + FLATPICKR_URL);
            };
            document.head.appendChild(s);
        });
    }

    function initCalendar() {
        var input = document.getElementById('datePicker');
        if (!input) return;

        loadFlatpickr().then(function () {
            // Détruire l'instance précédente si Turbo a récyclé la page
            if (input._flatpickr) {
                input._flatpickr.destroy();
            }

            flatpickr(input, {
                mode:       'range',
                inline:     true,
                dateFormat: 'Y-m-d',
                minDate:    'today',
                disable:    reservedRanges,
                appendTo:   document.querySelector('.fp-inline-container'),

                onChange: function (selectedDates) {
                    var fmt = function (d) {
                        return d.toLocaleDateString('fr-FR', {day: '2-digit', month: '2-digit', year: 'numeric'});
                    };

                    if (selectedDates.length >= 1) {
                        document.getElementById('dateDebutDisplay').value = fmt(selectedDates[0]);
                        document.getElementById('dateDebut').value = selectedDates[0].toISOString().slice(0, 10);
                    } else {
                        document.getElementById('dateDebutDisplay').value = '';
                        document.getElementById('dateDebut').value = '';
                    }

                    if (selectedDates.length === 2) {
                        document.getElementById('dateFinDisplay').value = fmt(selectedDates[1]);
                        document.getElementById('dateFin').value = selectedDates[1].toISOString().slice(0, 10);
                        document.getElementById('btnReserve').disabled = false;
                    } else {
                        document.getElementById('dateFinDisplay').value = '';
                        document.getElementById('dateFin').value = '';
                        document.getElementById('btnReserve').disabled = true;
                    }
                }
            });
        });
    }

    document.addEventListener('turbo:load', initCalendar);
})();
</script>

<script>
(function () {
    const btn = document.getElementById('favBtn');
    if (!btn) return;

    btn.addEventListener('click', function () {
        const bookId = btn.dataset.bookId;
        fetch('/favorite/toggle/' + bookId, {
            method: 'POST',
            headers: {'X-Requested-With': 'XMLHttpRequest'}
        })
        .then(r => r.json())
        .then(data => {
            const icon = btn.querySelector('i');
            const label = btn.querySelector('span');
            if (data.status === 'added') {
                icon.className = 'fa-solid fa-heart';
                label.textContent = 'Retirer des favoris';
                btn.classList.add('fav-btn--active');
                btn.title = 'Retirer des favoris';
            } else {
                icon.className = 'fa-regular fa-heart';
                label.textContent = 'Ajouter aux favoris';
                btn.classList.remove('fav-btn--active');
                btn.title = 'Ajouter aux favoris';
            }
        });
    });
})();
</script>

<script>
// ── Star rating interactive label ──
(function () {
    const labels = ['', 'Très nul', 'Décevant', 'Correct', 'Bien', 'Excellent'];
    const radios  = document.querySelectorAll('.star-rating input[type="radio"]');
    const hint    = document.getElementById('starLabel');
    if (!hint) return;

    radios.forEach(function (radio) {
        radio.addEventListener('change', function () {
            hint.textContent = this.value + '/5 — ' + labels[this.value];
        });
    });

    document.querySelectorAll('.star-rating label').forEach(function (label) {
        label.addEventListener('mouseenter', function () {
            const val = this.getAttribute('for').replace('star', '');
            hint.textContent = val + '/5 — ' + labels[val];
        });
    });
})();
</script>
{% endblock %}