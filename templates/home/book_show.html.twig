{% extends 'base.html.twig' %}

{% block title %}{{ book.title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="assets(styles/flatpickr.min.css)">

    <style>
        .book-container {
            max-width: 1000px;
            margin: auto;
            padding: 20px;
        }

        .book-header {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
        }

        .book-image {
            width: 200px;
            height: 300px;
            background: #eee;
            border-radius: 10px;
        }

        .book-info h1 {
            margin-bottom: 10px;
        }

        .badge {
            padding: 5px 10px;
            border-radius: 6px;
            font-size: 12px;
        }

        .available { background: #2ecc71; color: white; }
        .unavailable { background: #e74c3c; color: white; }

        /* CALENDAR */
        .calendar {
            margin-top: 40px;
        }

        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 5px;
        }

        .day {
            padding: 10px;
            text-align: center;
            border-radius: 6px;
            cursor: pointer;
            background: #ecf0f1;
        }

        .day.unavailable {
            background: #e74c3c;
            color: white;
            cursor: not-allowed;
        }

        .day.selected {
            background: #3498db;
            color: white;
        }

        .reserve-btn {
            margin-top: 20px;
            padding: 10px 20px;
            background: #3498db;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }
    </style>
{% endblock %}

{% block body %}
<div class="book-container">

    <!-- 📚 INFOS LIVRE -->
    <div class="book-header">
        <div class="book-image">
            <img src="{{ asset('images/' ~ book.image) }}" style="width:100%;height:100%;object-fit:cover;">
        </div>

        <div class="book-info">
            <h1>{{ book.title }}</h1>
            <p><strong>Auteur :</strong> {{ book.author.getAllName }}</p>
            <p>{{ book.description }}</p>

            <span class="badge {{ book.stock > 0 ? 'available' : 'unavailable' }}">
                {{ book.stock > 0 ? 'Disponible' : 'Indisponible' }}
            </span>
        </div>
    </div>

    <!-- 📅 CALENDRIER -->
    <div class="calendar">
        <h2>Choisir une date de réservation</h2>

        <div class="calendar-grid" id="calendar">
            {# Généré en JS #}
        </div>

    <form method="post" action="{{ path('app_reservation_create', {id: book.id}) }}">
        <input type="date" name="dateDebut" id="dateDebut" required>
        <input type="date" name="dateFin" id="dateFin" required>

        <button class="reserve-btn">Réserver</button>
    </form>
    </div>

</div>

<!-- ⚡ JS CALENDRIER -->
<script >
import flatpickr from './script/flatpickr.js';
flatpickr("#calendar", {
    mode: "range"
});
</script>

{% endblock %}