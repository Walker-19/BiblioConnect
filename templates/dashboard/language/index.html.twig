{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Gestion des langues{% endblock %}
{% block page_title %}Gestion des langues{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/books.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/dashboard-tables.css') }}">
{% endblock %}

{% block body %}

    <div class="dt-page-header">
        <div>
            <h1><i class="fas fa-language" style="color:#059669;margin-right:8px;"></i>Gestion des langues</h1>
            <p>Ajoutez, modifiez ou supprimez les langues disponibles.</p>
        </div>
        <button class="dt-btn dt-btn-primary" onclick="openModal('language')"><i class="fas fa-plus"></i> Ajouter une langue</button>
    </div>

    <div class="dt-search-wrap">
        <div class="dt-search-field">
            <input type="text" id="language-search" placeholder="Rechercher une langue…">
            <i class="fas fa-search search-icon"></i>
        </div>
        <button class="dt-reset-btn" onclick="clearLanguageSearch()">
            <i class="fas fa-times"></i> Réinitialiser
        </button>
    </div>

    <div class="dt-card">
        {% if languages is empty %}
            <div class="dt-empty">
                <i class="fas fa-language"></i>
                <p>Aucune langue disponible.</p>
            </div>
        {% else %}
            <table class="dt-table">
                <thead>
                    <tr>
                        <th>Langue</th>
                        <th class="col-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="languages-table-body">
                    {% for language in languages %}
                        <tr data-language-name="{{ language.nom|lower }}">
                            <td>
                                <span class="dt-badge dt-badge-green">
                                    <i class="fas fa-globe" style="margin-right:4px;"></i>{{ language.nom }}
                                </span>
                            </td>
                            <td class="col-right">
                                <div class="dt-actions">
                                    <button class="dt-btn dt-btn-view" onclick="showLanguageDetails('{{ language.nom }}')">
                                        <i class="fas fa-eye"></i> Détails
                                    </button>
                                    <a href="{{ path('admin_language_edit', {'id': language.id}) }}" class="dt-btn dt-btn-edit">
                                        <i class="fas fa-pen"></i> Éditer
                                    </a>
                                    <form method="POST" action="{{ path('admin_language_delete', {'id': language.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette langue ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ language.id) }}">
                                        <button type="submit" class="dt-btn dt-btn-delete"><i class="fas fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>

    {# Importer les modals #}
    {% include 'dashboard/book/modals.html.twig' %}

    {# ── MODAL DÉTAILS LANGUE ── #}
    <div id="language-details-overlay" onclick="closeModal('language-details')" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:100; align-items:center; justify-content:center;">
        <div onclick="event.stopPropagation()" style="background:#fff; border-radius:12px; padding:1.5rem; width:100%; max-width:500px; margin: 0 1rem;">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.25rem;">
                <span style="font-size:15px; font-weight:500;"><i class="fas fa-language"></i> Détails de la langue</span>
                <button onclick="closeModal('language-details')" style="background:none; border:none; font-size:18px; cursor:pointer; color:#888780;">✕</button>
            </div>

            <div style="display: grid; gap: 16px;">
                <div>
                    <label style="font-weight: 600; color: #999; font-size: 12px; text-transform: uppercase;">Nom de la langue</label>
                    <p id="details-language-nom" style="margin: 0; font-size: 16px; font-weight: 500; color: #1f2937;"></p>
                </div>
            </div>

            <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:1.5rem;">
                <button type="button" class="btn" onclick="closeModal('language-details')"><i class="fas fa-times"></i> Fermer</button>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {# Importer les scripts des modals #}
    {% include 'dashboard/book/modals_scripts.html.twig' %}

    <script>
        // Fonction pour afficher les détails de la langue
        function showLanguageDetails(nom) {
            document.getElementById('details-language-nom').textContent = nom;
            openModal('language-details');
        }

        {% verbatim %}
        // Fonction de recherche en temps réel pour les langues
        document.getElementById('language-search').addEventListener('keyup', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const tableRows = document.querySelectorAll('#languages-table-body tr');
            let visibleCount = 0;

            tableRows.forEach(row => {
                const languageName = row.getAttribute('data-language-name');
                if (languageName.includes(searchTerm)) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            // Afficher/masquer le message "aucun résultat"
            const noResultsMsg = document.getElementById('no-language-results-msg');
            if (visibleCount === 0 && searchTerm.length > 0) {
                if (!noResultsMsg) {
                    const tbody = document.getElementById('languages-table-body');
                    const msg = document.createElement('tr');
                    msg.id = 'no-language-results-msg';
                    msg.innerHTML = '<td colspan="2" style="text-align: center; padding: 20px; color: #888780;">Aucune langue trouvée.</td>';
                    tbody.appendChild(msg);
                }
            } else if (noResultsMsg) {
                noResultsMsg.remove();
            }
        });

        // Fonction pour réinitialiser la recherche des langues
        function clearLanguageSearch() {
            document.getElementById('language-search').value = '';
            document.getElementById('language-search').dispatchEvent(new Event('keyup'));
            document.getElementById('language-search').focus();
        }
        {% endverbatim %}
    </script>
{% endblock %}
