{% extends 'dashboard/dashboard.html.twig' %}

{% block page_title %}Gestion des livres{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/books.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/dashboard-tables.css') }}">
{% endblock %}

{% block title %}Gestion des livres{% endblock %}

{% block body %}

    <div class="dt-page-header">
        <div>
            <h1><i class="fas fa-book-open" style="color:#667eea;margin-right:8px;"></i>Gestion des ouvrages</h1>
            <p>Ajoutez, modifiez ou supprimez des ouvrages du catalogue.</p>
        </div>
        <button class="dt-btn dt-btn-primary" onclick="openModal('book')"><i class="fas fa-plus"></i> Ajouter un ouvrage</button>
    </div>

    <div class="dt-quick-add">
        <button class="dt-btn dt-btn-secondary" onclick="openModal('author')"><i class="fas fa-user-plus"></i> Ajouter un auteur</button>
        <button class="dt-btn dt-btn-secondary" onclick="openModal('language')"><i class="fas fa-language"></i> Ajouter une langue</button>
        <button class="dt-btn dt-btn-secondary" onclick="openModal('category')"><i class="fas fa-tag"></i> Ajouter une catégorie</button>
    </div>

    <div class="dt-search-wrap">
        <div class="dt-search-field">
            <input type="text" id="book-search" placeholder="Rechercher par titre ou auteur…">
            <i class="fas fa-search search-icon"></i>
        </div>
        <button class="dt-reset-btn" onclick="clearBookSearch()">
            <i class="fas fa-times"></i> Réinitialiser
        </button>
    </div>

    <div class="dt-card">
        {% if listBooks is empty %}
            <div class="dt-empty">
                <i class="fas fa-book-open"></i>
                <p>Aucun livre disponible.</p>
            </div>
        {% else %}
            <table class="dt-table">
                <thead>
                    <tr>
                        <th>Ouvrage</th>
                        <th>Langue</th>
                        <th>Catégories</th>
                        <th>Année</th>
                        <th>Stock</th>
                        <th class="col-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="books-table-body">
                    {% for book in listBooks %}
                        <tr data-book-info="{{ book.title|lower }} {{ book.author.getAllName()|lower }}">
                            <td>
                                <div class="dt-book-cell">
                                    {% if book.image %}
                                        <img src="{{ asset('images/' ~ book.image) }}" alt="{{ book.title }}" class="dt-book-thumb">
                                    {% else %}
                                        <div class="dt-book-thumb-ph"><i class="fas fa-book"></i></div>
                                    {% endif %}
                                    <div>
                                        <div class="dt-book-title">{{ book.title }}</div>
                                        <div class="dt-book-author">{{ book.author.getAllName() }}</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="dt-badge dt-badge-blue">{{ book.language.nom }}</span></td>
                            <td>
                                <div class="dt-tag-list">
                                    {% for category in book.categories %}
                                        <span class="dt-badge dt-badge-purple">{{ category.label }}</span>
                                    {% endfor %}
                                </div>
                            </td>
                            <td>{{ book.yearPublication }}</td>
                            <td>
                                {% if book.stock > 3 %}
                                    <span class="dt-stock-ok"><i class="fas fa-circle-check"></i> {{ book.stock }}</span>
                                {% elseif book.stock > 0 %}
                                    <span class="dt-stock-low"><i class="fas fa-triangle-exclamation"></i> {{ book.stock }}</span>
                                {% else %}
                                    <span class="dt-stock-none"><i class="fas fa-circle-xmark"></i> 0</span>
                                {% endif %}
                            </td>
                            <td class="col-right">
                                <div class="dt-actions">
                                    <button class="dt-btn dt-btn-view" onclick="showBookDetails({{ book.id }}, '{{ book.title }}', '{{ book.author.getAllName() }}', '{{ book.yearPublication }}', '{{ book.stock }}', '{{ book.language.nom }}', '{{ book.description|replace({'"': '\"'}) }}', '{{ book.isbn }}', '{{ book.image }}')">
                                        <i class="fas fa-eye"></i> Détails
                                    </button>
                                    <a href="{{ path('admin_book_edit', {'id': book.id}) }}" class="dt-btn dt-btn-edit">
                                        <i class="fas fa-pen"></i> Éditer
                                    </a>
                                    <form method="POST" action="{{ path('admin_book_delete', {'id': book.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer ce livre ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ book.id) }}">
                                        <button type="submit" class="dt-btn dt-btn-delete"><i class="fas fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>

    {# Import des modals #}
    {% include 'dashboard/book/modals.html.twig' %}

    {# ── MODAL DÉTAILS LIVRE ── #}
    <div id="book-details-overlay" onclick="closeModal('book-details')" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:100; align-items:center; justify-content:center;">
        <div onclick="event.stopPropagation()" style="background:#fff; border-radius:12px; padding:1.5rem; width:100%; max-width:700px; margin: 0 1rem; max-height: 85vh; overflow-y: auto;">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.25rem;">
                <span style="font-size:15px; font-weight:500;"><i class="fas fa-book"></i> Détails du livre</span>
                <button onclick="closeModal('book-details')" style="background:none; border:none; font-size:18px; cursor:pointer; color:#888780;">✕</button>
            </div>

            <div style="display: grid; gap: 16px;">
                <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 16px; align-items: start;">
                    <div style="text-align: center;">
                        <img id="details-book-cover" src="" alt="Couverture" style="width: 100%; max-width: 200px; height: auto; border-radius: 6px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    </div>
                    <div>
                        <div style="margin-bottom: 12px;">
                            <label style="font-weight: 600; color: #999; font-size: 12px; text-transform: uppercase;">Titre</label>
                            <p id="details-book-title" style="margin: 0; font-size: 16px; font-weight: 500; color: #1f2937;"></p>
                        </div>
                        <div style="margin-bottom: 12px;">
                            <label style="font-weight: 600; color: #999; font-size: 12px; text-transform: uppercase;">Auteur</label>
                            <p id="details-book-author" style="margin: 0; color: #555;"></p>
                        </div>
                        <div style="margin-bottom: 12px;">
                            <label style="font-weight: 600; color: #999; font-size: 12px; text-transform: uppercase;">Langue</label>
                            <p id="details-book-language" style="margin: 0; background: #f0f3ff; color: #667eea; padding: 4px 8px; border-radius: 3px; display: inline-block; font-size: 12px;"></p>
                        </div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                    <div>
                        <label style="font-weight: 600; color: #999; font-size: 12px; text-transform: uppercase;">Année de publication</label>
                        <p id="details-book-year" style="margin: 0; color: #555;"></p>
                    </div>
                    <div>
                        <label style="font-weight: 600; color: #999; font-size: 12px; text-transform: uppercase;">Stock</label>
                        <p id="details-book-stock" style="margin: 0; color: #555;"></p>
                    </div>
                </div>

                <div>
                    <label style="font-weight: 600; color: #999; font-size: 12px; text-transform: uppercase;">ISBN</label>
                    <p id="details-book-isbn" style="margin: 0; color: #555;"></p>
                </div>

                <div>
                    <label style="font-weight: 600; color: #999; font-size: 12px; text-transform: uppercase;">Description</label>
                    <p id="details-book-description" style="margin: 0; color: #555; line-height: 1.5; max-height: 150px; overflow-y: auto;"></p>
                </div>

                <div>
                    <label style="font-weight: 600; color: #999; font-size: 12px; text-transform: uppercase;">Catégories</label>
                    <div id="details-book-categories" style="display: flex; gap: 8px; flex-wrap: wrap;"></div>
                </div>
            </div>

            <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:1.5rem;">
                <button type="button" class="btn" onclick="closeModal('book-details')"><i class="fas fa-times"></i> Fermer</button>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {# Importer des scripts #}
    {% include 'dashboard/book/modals_scripts.html.twig' %}

    <script>
        {% if form is defined and not form.vars.valid and form.vars.submitted %}
            openModal('book');
        {% endif %}

        // Fonction pour afficher les détails du livre
        function showBookDetails(id, title, author, year, stock, language, description, isbn, image) {
            document.getElementById('details-book-title').textContent = title;
            document.getElementById('details-book-author').textContent = author;
            document.getElementById('details-book-language').textContent = language;
            document.getElementById('details-book-year').textContent = year;
            document.getElementById('details-book-stock').textContent = stock + ' exemplaire(s)';
            document.getElementById('details-book-isbn').textContent = isbn;
            document.getElementById('details-book-description').textContent = description;
            
            // Gérer l'image
            const coverImg = document.getElementById('details-book-cover');
            if (image) {
                coverImg.src = '/images/' + image;
                coverImg.style.background = 'none';
            } else {
                coverImg.src = '';
                coverImg.style.background = 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)';
                coverImg.innerHTML = '<i class="fas fa-book" style="font-size: 48px; color: white;"></i>';
            }

            openModal('book-details');
        }

        {% verbatim %}
        // Fonction de recherche en temps réel pour les livres
        document.getElementById('book-search').addEventListener('keyup', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const tableRows = document.querySelectorAll('#books-table-body tr');
            let visibleCount = 0;

            tableRows.forEach(row => {
                const bookInfo = row.getAttribute('data-book-info');
                if (bookInfo.includes(searchTerm)) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            // Afficher/masquer le message "aucun résultat"
            const noResultsMsg = document.getElementById('no-books-results-msg');
            if (visibleCount === 0 && searchTerm.length > 0) {
                if (!noResultsMsg) {
                    const tbody = document.getElementById('books-table-body');
                    const msg = document.createElement('tr');
                    msg.id = 'no-books-results-msg';
                    msg.innerHTML = '<td colspan="6" style="text-align: center; padding: 20px; color: #888780;">Aucun livre trouvé.</td>';
                    tbody.appendChild(msg);
                }
            } else if (noResultsMsg) {
                noResultsMsg.remove();
            }
        });

        // Fonction pour réinitialiser la recherche des livres
        function clearBookSearch() {
            document.getElementById('book-search').value = '';
            document.getElementById('book-search').dispatchEvent(new Event('keyup'));
            document.getElementById('book-search').focus();
        }

        // Fermer avec la touche Echap
        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') {
                document.querySelectorAll('[id$="-overlay"]').forEach(modal => {
                    if (modal.style.display === 'flex') {
                        const modalId = modal.id.replace('-overlay', '');
                        closeModal(modalId);
                    }
                });
            }
        });
        {% endverbatim %}
    </script>
{% endblock %}