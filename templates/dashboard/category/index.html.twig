{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Gestion des catégories{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/books.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/dashboard-tables.css') }}">
{% endblock %}

{% block body %}

    <div class="dt-page-header">
        <div>
            <h1><i class="fas fa-tags" style="color:#d97706;margin-right:8px;"></i>Gestion des catégories</h1>
            <p>Ajoutez, modifiez ou supprimez les catégories disponibles.</p>
        </div>
        <button class="dt-btn dt-btn-primary" onclick="openModal('category')"><i class="fas fa-plus"></i> Ajouter une catégorie</button>
    </div>

    <div class="dt-search-wrap">
        <div class="dt-search-field">
            <input type="text" id="category-search" placeholder="Rechercher une catégorie…">
            <i class="fas fa-search search-icon"></i>
        </div>
        <button class="dt-reset-btn" onclick="clearCategorySearch()">
            <i class="fas fa-times"></i> Réinitialiser
        </button>
    </div>

    <div class="dt-card">
        {% if categories is empty %}
            <div class="dt-empty">
                <i class="fas fa-tags"></i>
                <p>Aucune catégorie disponible.</p>
            </div>
        {% else %}
            <table class="dt-table">
                <thead>
                    <tr>
                        <th>Catégorie</th>
                        <th class="col-right">Actions</th>
                    </tr>
                </thead>
                <tbody id="categories-table-body">
                    {% for category in categories %}
                        <tr data-category-name="{{ category.label|lower }}">
                            <td>
                                <span class="dt-badge dt-badge-purple">
                                    <i class="fas fa-tag" style="margin-right:4px;"></i>{{ category.label }}
                                </span>
                            </td>
                            <td class="col-right">
                                <div class="dt-actions">
                                    <button class="dt-btn dt-btn-view" onclick="showCategoryDetails('{{ category.label }}')">
                                        <i class="fas fa-eye"></i> Détails
                                    </button>
                                    <a href="{{ path('admin_category_edit', {'id': category.id}) }}" class="dt-btn dt-btn-edit">
                                        <i class="fas fa-pen"></i> Éditer
                                    </a>
                                    <form method="POST" action="{{ path('admin_category_delete', {'id': category.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer cette catégorie ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                                        <button type="submit" class="dt-btn dt-btn-delete"><i class="fas fa-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>

    {# Importer les modals #}
    {% include 'dashboard/book/modals.html.twig' %}

    {# ── MODAL DÉTAILS CATÉGORIE ── #}
    <div id="category-details-overlay" onclick="closeModal('category-details')" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:100; align-items:center; justify-content:center;">
        <div onclick="event.stopPropagation()" style="background:#fff; border-radius:12px; padding:1.5rem; width:100%; max-width:500px; margin: 0 1rem;">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.25rem;">
                <span style="font-size:15px; font-weight:500;"><i class="fas fa-tag"></i> Détails de la catégorie</span>
                <button onclick="closeModal('category-details')" style="background:none; border:none; font-size:18px; cursor:pointer; color:#888780;">✕</button>
            </div>

            <div style="display: grid; gap: 16px;">
                <div>
                    <label style="font-weight: 600; color: #999; font-size: 12px; text-transform: uppercase;">Nom de la catégorie</label>
                    <p id="details-category-label" style="margin: 0; font-size: 16px; font-weight: 500; color: #1f2937;"></p>
                </div>
            </div>

            <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:1.5rem;">
                <button type="button" class="btn" onclick="closeModal('category-details')"><i class="fas fa-times"></i> Fermer</button>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {# Importer les scripts des modals #}
    {% include 'dashboard/book/modals_scripts.html.twig' %}

    <script>
        // Fonction pour afficher les détails de la catégorie
        function showCategoryDetails(label) {
            document.getElementById('details-category-label').textContent = label;
            openModal('category-details');
        }

        {% verbatim %}
        // Fonction de recherche en temps réel pour les catégories
        document.getElementById('category-search').addEventListener('keyup', function(e) {
            const searchTerm = e.target.value.toLowerCase();
            const tableRows = document.querySelectorAll('#categories-table-body tr');
            let visibleCount = 0;

            tableRows.forEach(row => {
                const categoryName = row.getAttribute('data-category-name');
                if (categoryName.includes(searchTerm)) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            // Afficher/masquer le message "aucun résultat"
            const noResultsMsg = document.getElementById('no-category-results-msg');
            if (visibleCount === 0 && searchTerm.length > 0) {
                if (!noResultsMsg) {
                    const tbody = document.getElementById('categories-table-body');
                    const msg = document.createElement('tr');
                    msg.id = 'no-category-results-msg';
                    msg.innerHTML = '<td colspan="2" style="text-align: center; padding: 20px; color: #888780;">Aucune catégorie trouvée.</td>';
                    tbody.appendChild(msg);
                }
            } else if (noResultsMsg) {
                noResultsMsg.remove();
            }
        });

        // Fonction pour réinitialiser la recherche des catégories
        function clearCategorySearch() {
            document.getElementById('category-search').value = '';
            document.getElementById('category-search').dispatchEvent(new Event('keyup'));
            document.getElementById('category-search').focus();
        }
        {% endverbatim %}
    </script>
{% endblock %}
