{% extends 'dashboard/dashboard.html.twig' %}

{% block title %}Éditer une Catégorie{% endblock %}
{% block page_title %}Éditer une Catégorie{% endblock %}
{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <h2>Éditer une Catégorie</h2>
            
            {{ form_start(form, {'attr': {'class': 'form-horizontal'}}) }}
                <div class="form-group mb-3">
                    {{ form_label(form.label, 'Libellé de la catégorie') }}
                    {{ form_widget(form.label, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.label) }}
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">
                        <i class="fa-solid fa-check"></i> Mettre à jour
                    </button>
                    <a href="{{ path('admin_categories') }}" class="btn btn-secondary">
                        <i class="fa-solid fa-xmark"></i> Annuler
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
